@{
    ViewData["Title"] = "Service Request";
}

<div class="page-header">
    <h1 class="page-title" style="font-size: 1.5rem;">Service Request</h1>
    <p class="page-subtitle">Fill out the form below. Our team will get back to you soon.</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="glass-card">
            <form>
                <div class="mb-3">
                    <label class="form-label">Your Name</label>
                    <input type="text" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <input type="email" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Phone Number</label>
                    <input type="text" class="form-control" required />
                </div>
                <div class="mb-4">
                    <label class="form-label">Event Description</label>
                    <textarea class="form-control" rows="4" required></textarea>
                </div>
                <div class="gap-actions">
                    <button type="submit" class="btn btn-accent">Submit Request</button>
                    <a href="/Services" class="btn btn-ghost">Back</a>
                </div>
            </form>
        </div>
    </div>
</div>
