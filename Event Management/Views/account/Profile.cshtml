@model Event_Management.Models.User
@{
    ViewData["Title"] = "My Profile";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="glass-card text-center">
            <img src="https://cdn-icons-png.flaticon.com/512/847/847969.png" class="profile-avatar mb-3" alt="Profile" />
            <h3 class="page-title mb-1" style="font-size: 1.35rem;">@Model.FullName</h3>
            <p class="text-muted mb-2">@Model.Email</p>
            <span class="badge-role mb-4 d-inline-block">@Model.UserType</span>
            <div class="d-grid gap-2">
                <a href="/Account/EditProfile" class="btn btn-accent">Edit Profile</a>
                <a href="/Account/Logout" class="btn btn-ghost">Logout</a>
            </div>
        </div>
    </div>
</div>
