@model IEnumerable<Event_Management.Models.Ticket>
@{
    ViewData["Title"] = "Tickets";
}

<div class="page-header">
    <h1 class="page-title">All Tickets</h1>
    <p class="page-subtitle">Review booked tickets across all events.</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-glass text-center mb-4">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-glass text-center mb-4">@TempData["ErrorMessage"]</div>
}

@if (!Model.Any())
{
    <div class="glass-card empty-state">
        <p class="mb-0 text-muted">No tickets have been booked yet.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-glass mb-0">
            <thead>
                <tr>
                    <th>Event</th>
                    <th>User</th>
                    <th>Ticket Type</th>
                    <th>Price</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in Model)
                {
                    <tr>
                        <td>@ticket.Event?.EventName</td>
                        <td>@ticket.User?.FullName</td>
                        <td>@ticket.TicketType</td>
                        <td>@ticket.Price.ToString("0.00") EGP</td>
                        <td class="text-end">
                            <form asp-action="DeleteAdmin" asp-route-id="@ticket.TicketId" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this ticket?');">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="gap-actions mt-4">
    <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-ghost">Back to Dashboard</a>
</div>
