@{
    ViewData["Title"] = "Access Denied";
    var isLoggedIn = Context.Session.GetInt32("UserId") != null;
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="glass-card text-center">
            <div class="mb-4" style="font-size: 3rem; line-height: 1; opacity: 0.85;" aria-hidden="true">&#128274;</div>
            <h1 class="page-title page-title--md mb-2">Access Denied</h1>
            <p class="page-subtitle mb-4">
                @if (isLoggedIn)
                {
                    <span>You are signed in, but your account does not have permission to view this page.</span>
                }
                else
                {
                    <span>Please sign in to continue.</span>
                }
            </p>

            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                @if (isLoggedIn)
                {
                    <a asp-controller="Home" asp-action="Index" class="btn btn-accent">Go to Home</a>
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-ghost">Sign out</a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-accent">Sign in</a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-ghost">Create account</a>
                }
            </div>
        </div>
    </div>
</div>
