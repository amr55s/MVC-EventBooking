@model Event_Management.Models.User
@{
    ViewData["Title"] = "Edit Profile";
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger alert-glass mb-4">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p class="mb-0">@error.ErrorMessage</p>
        }
    </div>
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="glass-card">
            <h3 class="page-title text-center mb-4" style="font-size: 1.35rem;">Edit Profile</h3>
            <form asp-action="EditProfile" method="post">
                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <input asp-for="FullName" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <input asp-for="Email" type="email" class="form-control" required />
                </div>
                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <input asp-for="Password" type="password" class="form-control" required />
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-accent">Save Changes</button>
                    <a href="/Account/Profile" class="btn btn-ghost">Back to Profile</a>
                </div>
            </form>
        </div>
    </div>
</div>
