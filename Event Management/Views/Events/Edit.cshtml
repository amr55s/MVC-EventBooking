@model Event_Management.Models.Event
@{
    ViewData["Title"] = "Edit Event";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="glass-card">
            <h2 class="page-title mb-4" style="font-size: 1.5rem;">Edit Event</h2>
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="EventId" />
                <div class="mb-3">
                    <label asp-for="EventName" class="form-label"></label>
                    <input asp-for="EventName" class="form-control" />
                    <span asp-validation-for="EventName" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="EventDate" class="form-label"></label>
                    <input asp-for="EventDate" class="form-control" />
                    <span asp-validation-for="EventDate" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ImagePath" class="form-label"></label>
                    <input asp-for="ImagePath" class="form-control" />
                    <span asp-validation-for="ImagePath" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="LocationId" class="form-label"></label>
                    <select asp-for="LocationId" class="form-select" asp-items="ViewBag.LocationId"></select>
                    <span asp-validation-for="LocationId" class="text-danger"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="OrganizerId" class="form-label"></label>
                    <select asp-for="OrganizerId" class="form-select" asp-items="ViewBag.OrganizerId"></select>
                    <span asp-validation-for="OrganizerId" class="text-danger"></span>
                </div>
                <div class="gap-actions">
                    <button type="submit" class="btn btn-accent">Save</button>
                    <a asp-action="Index" class="btn btn-ghost">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
