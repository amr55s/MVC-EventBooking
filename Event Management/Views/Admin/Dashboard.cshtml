@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page-header">
    <h1 class="page-title">Admin Dashboard</h1>
    <p class="page-subtitle">Manage the entire event system from one place.</p>
</div>

<div class="row g-4 text-center mb-5">
    <div class="col-md-4">
        <div class="glass stat-card">
            <h5 class="card-title">Total Events</h5>
            <p class="stat-value">@ViewBag.EventCount</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="glass stat-card">
            <h5 class="card-title">Registered Users</h5>
            <p class="stat-value">@ViewBag.UserCount</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="glass stat-card">
            <h5 class="card-title">Total Tickets</h5>
            <p class="stat-value">@ViewBag.TicketCount</p>
        </div>
    </div>
</div>

<div class="glass-card mb-5">
    <h4 class="text-center mb-4" style="font-size: 1.15rem;">Latest Events</h4>
    <div class="table-responsive">
        <table class="table table-glass mb-0">
            <thead>
                <tr>
                    <th>Event Name</th>
                    <th>Date</th>
                    <th>Location</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in ViewBag.LatestEvents)
                {
                    <tr>
                        <td>@item.EventName</td>
                        <td>@item.EventDate.ToString("yyyy-MM-dd")</td>
                        <td>@item.Location?.LocationName</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="chart-container mb-5">
    <h4 class="text-center mb-4" style="font-size: 1.15rem;">System Overview</h4>
    <canvas id="dashboardChart" height="100"></canvas>
</div>

<div class="text-center">
    <h4 class="mb-3" style="font-size: 1.15rem;">Quick Actions</h4>
    <div class="row g-3 justify-content-center mb-4">
        <div class="col-md-4">
            <a href="/Events/Index" class="btn btn-primary-glass w-100">View All Events</a>
        </div>
        <div class="col-md-4">
            <a href="/Users/Index" class="btn btn-primary-glass w-100">View All Users</a>
        </div>
        <div class="col-md-4">
            <a href="/Tickets/Index" class="btn btn-primary-glass w-100">View All Tickets</a>
        </div>
    </div>
    <div class="gap-actions">
        <a href="/Events/Create" class="btn btn-accent">Create New Event</a>
        <a href="/Services/Index" class="btn btn-ghost">Manage Services</a>
    </div>
</div>

@section Scripts {
    <script>
        const ctx = document.getElementById('dashboardChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Events', 'Users', 'Tickets'],
                datasets: [{
                    label: 'Count',
                    data: [@ViewBag.EventCount, @ViewBag.UserCount, @ViewBag.TicketCount],
                    backgroundColor: ['rgba(184, 149, 74, 0.7)', 'rgba(61, 90, 128, 0.7)', 'rgba(30, 45, 61, 0.5)'],
                    borderColor: ['#b8954a', '#3d5a80', '#1e2d3d'],
                    borderWidth: 1,
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' } }, x: { grid: { display: false } } }
            }
        });
    </script>
}
