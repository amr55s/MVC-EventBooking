@{
    ViewData["Title"] = "Welcome to EventMaster";
}

<div class="page-header">
    <h1 class="page-title">EventMaster</h1>
    <p class="page-subtitle lead">Your partner in professional event planning and unforgettable moments.</p>
</div>

<div class="row g-4 align-items-center">
    <div class="col-md-6">
        <img src="/images/event-banner.jpg" class="hero-image" alt="Event planning" />
    </div>
    <div class="col-md-6">
        <div class="glass-card glass-card--compact">
            <h3 class="mb-3">About Us</h3>
            <p>
                EventMaster is a leading event management company specializing in organizing weddings,
                conferences, concerts, and corporate events. With a dedicated team and creative vision,
                we ensure every detail of your event is perfect — from start to finish.
            </p>
            
            @if (Context.Session.GetString("UserType") == "Admin")
            {
                <a class="btn btn-accent" asp-controller="Events" asp-action="Create">Create Event</a>
            }
            else
            {
                <a class="btn btn-accent" asp-controller="Tickets" asp-action="Create">Book Event</a>
            }
        </div>
    </div>
</div>

<section class="section-spacing">
    <div class="page-header mb-4">
        <h2 class="page-title page-title--md">What Our Clients Say</h2>
    </div>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="glass testimonial-card">
                <p>"EventMaster turned my wedding day into a fairytale. Everything was perfect!"</p>
                <small>— Sarah A.</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass testimonial-card">
                <p>"Highly professional team. Our company conference was a huge success!"</p>
                <small>— Ahmed R.</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass testimonial-card">
                <p>"From planning to execution, they were amazing. I recommend them 100%."</p>
                <small>— Nour M.</small>
            </div>
        </div>
    </div>
</section>
