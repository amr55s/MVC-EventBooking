@model Event_Management.Models.Ticket
@{
    ViewData["Title"] = "Book Your Event";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-glass text-center mb-4">@TempData["SuccessMessage"]</div>
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="glass-card">
            <h3 class="page-title text-center mb-4" style="font-size: 1.35rem;">Book an Event</h3>
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label">Choose Event</label>
                    <select asp-for="EventId" asp-items="ViewBag.EventId" class="form-select" required>
                        <option value="">-- Select an Event --</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Ticket Type</label>
                    <input asp-for="TicketType" class="form-control" required />
                </div>
                <div class="mb-4">
                    <label class="form-label">Price</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" required />
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-accent">Confirm Booking</button>
                    <a href="/" class="btn btn-ghost">Home</a>
                </div>
            </form>
        </div>
    </div>
</div>
