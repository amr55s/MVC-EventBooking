@model Event_Management.Models.Event
@{
    ViewData["Title"] = "Event Created";
}

<div class="glass-card">
    <h2 class="text-success mb-3" style="font-size: 1.5rem;">Event Created Successfully</h2>
    <hr class="opacity-25" />
    <div class="row g-4 align-items-center">
        <div class="col-md-4">
            <img src="@Model.ImagePath" class="hero-image" alt="@Model.EventName" />
        </div>
        <div class="col-md-8">
            <h4 class="mb-3">@Model.EventName</h4>
            <p><strong>Date:</strong> @Model.EventDate.ToShortDateString()</p>
            <p><strong>Location:</strong> @Model.Location?.LocationName</p>
            <p class="mb-4"><strong>Organizer:</strong> @Model.Organizer?.FullName</p>
            <a href="/Events" class="btn btn-primary-glass">Back to Events</a>
        </div>
    </div>
</div>
