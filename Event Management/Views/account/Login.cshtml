@{
    ViewData["Title"] = "Login";
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger alert-glass text-center mb-4">@ViewBag.Error</div>
}

<div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">
        <div class="glass-card">
            <h3 class="page-title text-center mb-4" style="font-size: 1.35rem;">Login</h3>
                <form asp-controller="Account" asp-action="Login" method="post">
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control" required />
                </div>
                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-accent w-100">Sign in</button>
            </form>
        </div>
    </div>
</div>
