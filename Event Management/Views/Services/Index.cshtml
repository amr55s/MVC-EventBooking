@{
    ViewData["Title"] = "Our Services";
}

<div class="page-header">
    <h1 class="page-title">Our Services</h1>
    <p class="page-subtitle lead">
        Tailored event management solutions to turn your vision into an unforgettable reality.
    </p>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="glass service-card">
            <h5 class="card-title">Private Events</h5>
            <p class="card-text">Weddings, birthdays, graduations and special moments — planned from A to Z.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="glass service-card">
            <h5 class="card-title">Conferences & Business</h5>
            <p class="card-text">Professional setup with audio/visuals, scheduling, and guest management.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="glass service-card">
            <h5 class="card-title">Public Shows & Festivals</h5>
            <p class="card-text">Concerts, cultural shows, and entertainment for large audiences.</p>
        </div>
    </div>
    <div class="col-md-6">
        <div class="glass service-card">
            <h5 class="card-title">Venue & Equipment Rental</h5>
            <p class="card-text">Top venues and professional lighting, sound systems, and more.</p>
        </div>
    </div>
    <div class="col-md-6">
        <div class="glass service-card">
            <h5 class="card-title">Ticketing & Guest Management</h5>
            <p class="card-text">Digital tickets, attendance tracking, and smooth check-ins.</p>
        </div>
    </div>
</div>
