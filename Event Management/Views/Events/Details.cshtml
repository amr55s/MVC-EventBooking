@model Event_Management.Models.Event
@{
    ViewData["Title"] = "Event Details";
}

<div class="glass-card">
    <h1 class="page-title mb-4" style="font-size: 1.5rem;">@Model.EventName</h1>
    <dl class="row mb-0">
        <dt class="col-sm-3 text-muted">Date</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.EventDate)</dd>
        <dt class="col-sm-3 text-muted">Image</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.ImagePath)</dd>
        <dt class="col-sm-3 text-muted">Location</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Location.LocationId)</dd>
        <dt class="col-sm-3 text-muted">Organizer</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Organizer.UserId)</dd>
    </dl>
    <div class="gap-actions mt-4 pt-3 border-top">
        <a asp-action="Edit" asp-route-id="@Model?.EventId" class="btn btn-accent">Edit</a>
        <a asp-action="Index" class="btn btn-ghost">Back to List</a>
    </div>
</div>
