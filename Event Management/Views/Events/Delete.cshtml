@model Event_Management.Models.Event
@{
    ViewData["Title"] = "Delete Event";
}

<div class="glass-card">
    <h2 class="page-title mb-2" style="font-size: 1.5rem;">Delete Event</h2>
    <p class="text-muted mb-4">Are you sure you want to delete this event?</p>
    <dl class="row">
        <dt class="col-sm-3 text-muted">Name</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.EventName)</dd>
        <dt class="col-sm-3 text-muted">Date</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.EventDate)</dd>
        <dt class="col-sm-3 text-muted">Location</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Location.LocationId)</dd>
    </dl>
    <form asp-action="Delete" class="gap-actions mt-4">
        <input type="hidden" asp-for="EventId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-ghost">Cancel</a>
    </form>
</div>
