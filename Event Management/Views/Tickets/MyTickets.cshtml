@model List<Event_Management.Models.Ticket>
@{
    ViewData["Title"] = "My Tickets";
}

<div class="page-header">
    <h1 class="page-title">My Tickets</h1>
    <p class="page-subtitle">Your booked events.</p>
</div>

@if (Model.Count == 0)
{
    <div class="glass-card empty-state">
        <p class="mb-0 text-muted">You have not booked any tickets yet.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-glass mb-0">
            <thead>
                <tr>
                    <th>Event Name</th>
                    <th>Ticket Type</th>
                    <th>Price</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in Model)
                {
                    <tr>
                        <td>@ticket.Event?.EventName</td>
                        <td>@ticket.TicketType</td>
                        <td>@ticket.Price.ToString("0.00") EGP</td>
                        <td>
                            <a class="btn btn-sm btn-ghost text-danger" asp-action="Delete" asp-route-id="@ticket.TicketId" onclick="return confirm('Delete this ticket?');">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
