@model Event_Management.Models.Event
@{
    ViewData["Title"] = "Create Event";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="glass-card">
            <h2 class="page-title text-center mb-4" style="font-size: 1.5rem;">Create New Event</h2>

            @if (ViewBag.LocationWarning != null)
            {
                <div class="alert alert-warning alert-glass mb-4">@ViewBag.LocationWarning</div>
            }

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-glass text-center mb-4">@TempData["Success"]</div>
            }

            <form asp-action="Create" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="EventName" class="form-label"></label>
                    <input asp-for="EventName" class="form-control" />
                    <span asp-validation-for="EventName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="EventDate" class="form-label"></label>
                    <input asp-for="EventDate" class="form-control" type="date" />
                    <span asp-validation-for="EventDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="LocationId" class="form-label"></label>
                    <select asp-for="LocationId" class="form-select" asp-items="ViewBag.LocationId"></select>
                </div>

                <div class="mb-3">
                    <label asp-for="OrganizerId" class="form-label"></label>
                    <select asp-for="OrganizerId" class="form-select" asp-items="ViewBag.OrganizerId"></select>
                </div>

                <div class="mb-4">
                    <label class="form-label">Upload Event Image</label>
                    <input type="file" name="Image" class="form-control" onchange="previewImage(event)" />
                    <img id="imagePreview" src="#" alt="Preview" class="mt-3 hero-image" style="max-height: 200px; display: none;" />
                </div>

                <div class="gap-actions">
                    <button type="submit" class="btn btn-accent">Create Event</button>
                    <a asp-action="Index" class="btn btn-ghost">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function previewImage(event) {
            const reader = new FileReader();
            reader.onload = function () {
                const output = document.getElementById('imagePreview');
                output.src = reader.result;
                output.style.display = 'block';
            };
            reader.readAsDataURL(event.target.files[0]);
        }
    </script>
}
